<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Regulatory Repository</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@300;400;500;700;900&family=Noto+Sans:ital,wght@0,300;0,400;0,500;0,700;1,400&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="assets/styles.css">
</head>
<body>

  <header class="site-header">
    <div class="header-inner">
      <div class="header-brand">
        <span class="header-title">Regulatory Repository</span>
      </div>

      <div class="search-wrap">
        <input id="search" type="search" autocomplete="off" aria-label="Search"
               placeholder="Title, citation, tags, or body text…">
      </div>

      <div class="header-actions">
        <button type="button" class="btn-util" id="copy-link">Copy link</button>
        <button type="button" class="btn-util" id="theme-toggle">Dark</button>
      </div>
    </div>

    <div class="view-bar" role="group" aria-label="Content availability">
      <span class="view-bar-label">Show</span>
      <label class="avail-option" title="Records with full regulation text from a live source">
        <input type="checkbox" id="avail-full" data-avail="full" checked>
        Full text
      </label>
      <label class="avail-option" title="Standards requiring purchase or institutional access">
        <input type="checkbox" id="avail-paywall" data-avail="paywall">
        Paywall
      </label>
      <label class="avail-option" title="Catalog stubs with no live connector yet">
        <input type="checkbox" id="avail-noconn" data-avail="noconn">
        No live connection
      </label>
    </div>
  </header>

  <div class="layout">
    <aside class="filters" aria-label="Filters">
      <div class="filters-inner">
        <button type="button" class="clear-button hidden" id="clear-filters">Clear all filters</button>
        <form id="filters-form"></form>
      </div>
    </aside>

    <main>
      <button type="button" class="filters-toggle" id="filters-toggle" aria-expanded="false">Filters</button>
      <p id="result-count" aria-live="polite">Showing 0 of 0</p>
      <section class="cards" id="cards" aria-label="Regulations"></section>
      <button type="button" class="load-more hidden" id="load-more">Load more</button>
    </main>
  </div>

  <div id="tip" role="tooltip" aria-hidden="true"></div>

  <footer class="site-footer">
    <span>Built {{ build_meta.timestamp }} &nbsp;&bull;&nbsp; {{ build_meta.count }} regulations &nbsp;&bull;&nbsp; {{ build_meta.region_counts|length }} regions</span>
  </footer>
  <script src="assets/vendor/minisearch.min.js"></script>
  <script src="assets/app.js"></script>
</body>
</html>
