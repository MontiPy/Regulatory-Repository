<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Regulatory Repository</title>
  <style>
    :root {
      color-scheme: light;
      --bg: #f6f7f9;
      --panel: #ffffff;
      --text: #17202a;
      --muted: #5f6c7b;
      --line: #d9e0e8;
      --accent: #146c94;
      --accent-dark: #0f4f6f;
      --warn: #9a5b00;
      --danger: #9f2d20;
      --ok: #24724d;
      --chip: #edf3f7;
      --shadow: 0 1px 2px rgba(23, 32, 42, 0.08);
    }

    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      background: var(--bg);
      color: var(--text);
      font-family: Arial, Helvetica, sans-serif;
      font-size: 16px;
      line-height: 1.5;
    }

    a {
      color: var(--accent-dark);
    }

    button,
    input[type="search"],
    input[type="checkbox"] {
      font: inherit;
    }

    button:focus-visible,
    input:focus-visible,
    summary:focus-visible,
    a:focus-visible {
      outline: 3px solid rgba(20, 108, 148, 0.35);
      outline-offset: 2px;
    }

    .site-header {
      position: sticky;
      top: 0;
      z-index: 20;
      display: grid;
      grid-template-columns: minmax(220px, 1fr) minmax(280px, 520px);
      gap: 24px;
      align-items: center;
      padding: 16px 24px;
      background: rgba(255, 255, 255, 0.96);
      border-bottom: 1px solid var(--line);
      backdrop-filter: blur(8px);
    }

    .site-header h1 {
      margin: 0;
      font-size: 24px;
      line-height: 1.1;
    }

    .build-info {
      margin: 4px 0 0;
      color: var(--muted);
      font-size: 14px;
    }

    .search-wrap {
      display: grid;
      gap: 6px;
    }

    .search-wrap label {
      color: var(--muted);
      font-size: 13px;
      font-weight: 700;
      text-transform: uppercase;
    }

    #search {
      width: 100%;
      min-height: 42px;
      padding: 10px 12px;
      border: 1px solid var(--line);
      border-radius: 6px;
      background: #fff;
      color: var(--text);
    }

    .layout {
      display: grid;
      grid-template-columns: 280px minmax(0, 1fr);
      min-height: calc(100vh - 82px);
    }

    .filters {
      border-right: 1px solid var(--line);
      background: #fbfcfd;
      padding: 18px 16px 28px;
    }

    .filters-inner {
      position: sticky;
      top: 92px;
      display: grid;
      gap: 12px;
      max-height: calc(100vh - 112px);
      overflow: auto;
      padding-right: 4px;
    }

    .clear-button,
    .load-more,
    .expand-button {
      border: 1px solid var(--accent);
      border-radius: 6px;
      background: var(--accent);
      color: #fff;
      cursor: pointer;
      font-weight: 700;
    }

    .clear-button {
      min-height: 38px;
      width: 100%;
    }

    details {
      border: 1px solid var(--line);
      border-radius: 6px;
      background: var(--panel);
    }

    summary {
      cursor: pointer;
      padding: 10px 12px;
      font-weight: 700;
    }

    .facet-options {
      display: grid;
      gap: 8px;
      max-height: 220px;
      overflow: auto;
      padding: 0 12px 12px;
    }

    .facet-option {
      display: grid;
      grid-template-columns: 18px minmax(0, 1fr);
      gap: 8px;
      align-items: start;
      color: var(--text);
      font-size: 14px;
    }

    main {
      padding: 22px 24px 36px;
    }

    #result-count {
      margin: 0 0 14px;
      color: var(--muted);
      font-weight: 700;
    }

    .cards {
      display: grid;
      gap: 14px;
    }

    .reg-card {
      border: 1px solid var(--line);
      border-radius: 8px;
      background: var(--panel);
      box-shadow: var(--shadow);
      padding: 16px;
    }

    .card-top {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      gap: 14px;
      align-items: start;
    }

    .reg-title {
      margin: 0 0 8px;
      font-size: 20px;
      line-height: 1.25;
    }

    .badges,
    .chips {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
    }

    .badge,
    .chip {
      display: inline-flex;
      align-items: center;
      min-height: 24px;
      border-radius: 999px;
      padding: 2px 8px;
      background: var(--chip);
      color: var(--text);
      font-size: 13px;
      font-weight: 700;
      line-height: 1.3;
    }

    .badge.region {
      background: #dff1f4;
      color: #164f5c;
    }

    .badge.status-in-force {
      background: #e3f3eb;
      color: var(--ok);
    }

    .badge.status-proposed {
      background: #fff1d8;
      color: var(--warn);
    }

    .badge.status-withdrawn,
    .badge.status-superseded,
    .badge.untagged {
      background: #fbe4df;
      color: var(--danger);
    }

    .summary {
      margin: 12px 0 0;
      color: #344354;
    }

    .expand-button {
      min-width: 92px;
      min-height: 36px;
      padding: 7px 12px;
    }

    .expanded {
      display: grid;
      gap: 14px;
      margin-top: 16px;
      border-top: 1px solid var(--line);
      padding-top: 16px;
    }

    .body-html {
      overflow-x: auto;
    }

    .body-html table {
      width: 100%;
      border-collapse: collapse;
    }

    .body-html th,
    .body-html td {
      border: 1px solid var(--line);
      padding: 8px;
      text-align: left;
      vertical-align: top;
    }

    .meta-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 10px 14px;
      color: var(--muted);
      font-size: 14px;
    }

    .meta-grid strong {
      color: var(--text);
    }

    .empty-state {
      border: 1px dashed var(--line);
      border-radius: 8px;
      background: var(--panel);
      color: var(--muted);
      padding: 24px;
      text-align: center;
    }

    .load-more {
      display: block;
      min-height: 42px;
      margin: 18px auto 0;
      padding: 8px 18px;
    }

    .hidden {
      display: none;
    }

    @media (max-width: 820px) {
      .site-header,
      .layout {
        grid-template-columns: 1fr;
      }

      .site-header {
        gap: 12px;
      }

      .filters {
        border-right: 0;
        border-bottom: 1px solid var(--line);
      }

      .filters-inner {
        position: static;
        max-height: none;
      }

      .card-top {
        grid-template-columns: 1fr;
      }

      .expand-button {
        justify-self: start;
      }
    }
  </style>
</head>
<body>
  <header class="site-header">
    <div>
      <h1>Regulatory Repository</h1>
      <p class="build-info">Built {{ build_meta.timestamp }} &bull; {{ build_meta.count }} regulations across {{ build_meta.region_counts|length }} regions</p>
    </div>
    <div class="search-wrap">
      <label for="search">Search</label>
      <input id="search" type="search" autocomplete="off" placeholder="Search title, citation, UN equivalent, tags, or body">
    </div>
  </header>

  <div class="layout">
    <aside class="filters" aria-label="Filters">
      <div class="filters-inner">
        <button type="button" class="clear-button" id="clear-filters">Clear all filters</button>
        <form id="filters-form"></form>
      </div>
    </aside>

    <main>
      <p id="result-count" aria-live="polite">Showing 0 of 0</p>
      <section class="cards" id="cards" aria-label="Regulations"></section>
      <button type="button" class="load-more hidden" id="load-more">Load more</button>
    </main>
  </div>

  <script>
    const REGS = {{ records_json | safe }};
    const TAXONOMY = {{ taxonomy | safe }};

    const PAGE_SIZE = 50;
    const FILTERS = [
      { key: "region", label: "Region", taxonomyKey: "regions" },
      { key: "status", label: "Status", taxonomyKey: "statuses" },
      { key: "tagging_status", label: "Tagging Status", taxonomyKey: "tagging_statuses" },
      { key: "vehicle_categories", label: "Vehicle Category", taxonomyKey: "vehicle_categories" },
      { key: "systems", label: "System", taxonomyKey: "systems" },
      { key: "commodities", label: "Commodity", taxonomyKey: "commodities" }
    ];

    const searchInput = document.querySelector("#search");
    const filtersForm = document.querySelector("#filters-form");
    const cards = document.querySelector("#cards");
    const resultCount = document.querySelector("#result-count");
    const loadMore = document.querySelector("#load-more");
    const clearFilters = document.querySelector("#clear-filters");
    const expanded = new Set();
    const recordById = new Map(REGS.map((record) => [record.id, record]));
    let visibleLimit = PAGE_SIZE;
    let urlTimer = null;

    function escapeHtml(value) {
      return String(value ?? "")
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll('"', "&quot;")
        .replaceAll("'", "&#039;");
    }

    function slug(value) {
      return String(value ?? "").replace(/[^a-zA-Z0-9_-]/g, "-");
    }

    function statusClass(status) {
      return `status-${String(status || "").toLowerCase().replace(/[^a-z0-9]+/g, "-")}`;
    }

    function normalize(value) {
      return String(value ?? "").toLowerCase();
    }

    function matchesFacet(values, selected) {
      if (!selected || selected.size === 0) return true;
      return values.some((value) => selected.has(value));
    }

    function matchesText(r, query) {
      const q = normalize(query).trim();
      if (!q) return true;
      const base = [
        r.title,
        r.citation,
        (r.aliases || []).join(" "),
        r.summary_text,
        (r.un_equivalent || []).join(" "),
        (r.tags || []).join(" ")
      ].join(" ");
      if (normalize(base).includes(q)) return true;
      return q.length >= 3 && normalize(r.body_html).includes(q);
    }

    function readSelections() {
      const selections = {};
      FILTERS.forEach((filter) => {
        selections[filter.key] = new Set(
          Array.from(filtersForm.querySelectorAll(`input[name="${filter.key}"]:checked`)).map((input) => input.value)
        );
      });
      return selections;
    }

    function getVisibleRecords() {
      const query = searchInput.value;
      const sel = readSelections();
      const visible = REGS.filter(r =>
        matchesText(r, query) &&
        matchesFacet([r.region], sel.region) &&
        matchesFacet([r.status], sel.status) &&
        matchesFacet([r.tagging_status], sel.tagging_status) &&
        matchesFacet(r.vehicle_categories || [], sel.vehicle_categories) &&
        matchesFacet(r.systems || [], sel.systems) &&
        matchesFacet(r.commodities || [], sel.commodities)
      );
      return visible;
    }

    function facetChips(label, values) {
      if (!values || values.length === 0) return "";
      const chips = values.map((value) => `<span class="chip">${escapeHtml(value)}</span>`).join("");
      return `<div><strong>${escapeHtml(label)}:</strong><div class="chips">${chips}</div></div>`;
    }

    function relatedLinks(values) {
      if (!values || values.length === 0) return "";
      const links = values.map((id) => {
        const record = recordById.get(id);
        if (!record) return `<span class="chip">${escapeHtml(id)}</span>`;
        return `<a class="chip" href="#reg-${slug(id)}">${escapeHtml(record.title || id)}</a>`;
      }).join("");
      return `<div><strong>Related:</strong><div class="chips">${links}</div></div>`;
    }

    function expandedContent(record) {
      const source = record.source_url
        ? `<a href="${escapeHtml(record.source_url)}" rel="noopener noreferrer">${escapeHtml(record.source_url)}</a>`
        : "";
      return `
        <div class="expanded">
          <div class="body-html">${record.body_html || ""}</div>
          <div class="meta-grid">
            ${facetChips("Commodities", record.commodities)}
            ${facetChips("Systems", record.systems)}
            ${facetChips("Vehicle Categories", record.vehicle_categories)}
            ${facetChips("UN Equivalent", record.un_equivalent)}
            ${relatedLinks(record.related)}
            <div><strong>Source:</strong> ${source}</div>
            <div><strong>Last Pulled:</strong> ${escapeHtml(record.last_pulled || "")}</div>
            <div><strong>Tagged At:</strong> ${escapeHtml(record.tagged_at || "")}</div>
          </div>
        </div>
      `;
    }

    function cardTemplate(record) {
      const isExpanded = expanded.has(record.id);
      const untagged = record.tagging_status === "untagged"
        ? '<span class="badge untagged">untagged</span>'
        : "";
      return `
        <article class="reg-card" id="reg-${slug(record.id)}">
          <div class="card-top">
            <div>
              <h2 class="reg-title">${escapeHtml(record.title || record.id)}</h2>
              <div class="badges">
                <span class="badge region">${escapeHtml(record.region)}</span>
                <span class="badge">${escapeHtml(record.citation)}</span>
                <span class="badge ${statusClass(record.status)}">${escapeHtml(record.status)}</span>
                ${untagged}
              </div>
              <p class="summary">${escapeHtml(record.summary_text || "No summary available.")}</p>
            </div>
            <button type="button" class="expand-button" data-expand="${escapeHtml(record.id)}" aria-expanded="${isExpanded ? "true" : "false"}">
              ${isExpanded ? "Collapse" : "Expand"}
            </button>
          </div>
          ${isExpanded ? expandedContent(record) : ""}
        </article>
      `;
    }

    function render() {
      const visible = getVisibleRecords();
      const renderable = visible.slice(0, visibleLimit);
      resultCount.textContent = `Showing ${renderable.length} of ${visible.length}`;
      cards.innerHTML = renderable.length
        ? renderable.map(cardTemplate).join("")
        : '<div class="empty-state">No regulations match the current filters.</div>';
      loadMore.classList.toggle("hidden", visible.length <= visibleLimit);
    }

    function buildFilters() {
      filtersForm.innerHTML = FILTERS.map((filter) => {
        const options = TAXONOMY[filter.taxonomyKey] || [];
        const controls = options.map((value) => {
          const id = `${filter.key}-${slug(value)}`;
          return `
            <label class="facet-option" for="${escapeHtml(id)}">
              <input type="checkbox" id="${escapeHtml(id)}" name="${escapeHtml(filter.key)}" value="${escapeHtml(value)}">
              <span>${escapeHtml(value)}</span>
            </label>
          `;
        }).join("");
        return `
          <details open>
            <summary>${escapeHtml(filter.label)}</summary>
            <div class="facet-options">${controls}</div>
          </details>
        `;
      }).join("");
    }

    function valuesFromParams(params, key) {
      return params.getAll(key).flatMap((value) => value.split(",")).filter(Boolean);
    }

    function applyUrlParams() {
      const params = new URLSearchParams(window.location.search);
      searchInput.value = params.get("q") || "";
      FILTERS.forEach((filter) => {
        const selected = new Set(valuesFromParams(params, filter.key));
        filtersForm.querySelectorAll(`input[name="${filter.key}"]`).forEach((input) => {
          input.checked = selected.has(input.value);
        });
      });
    }

    function syncUrl() {
      window.clearTimeout(urlTimer);
      urlTimer = window.setTimeout(() => {
        const params = new URLSearchParams();
        const query = searchInput.value.trim();
        if (query) params.set("q", query);
        const selections = readSelections();
        FILTERS.forEach((filter) => {
          Array.from(selections[filter.key]).forEach((value) => params.append(filter.key, value));
        });
        const queryString = params.toString();
        const nextUrl = queryString ? `${window.location.pathname}?${queryString}` : window.location.pathname;
        history.replaceState(null, "", nextUrl);
      }, 150);
    }

    searchInput.addEventListener("input", () => {
      visibleLimit = PAGE_SIZE;
      render();
      syncUrl();
    });

    filtersForm.addEventListener("change", () => {
      visibleLimit = PAGE_SIZE;
      render();
      syncUrl();
    });

    cards.addEventListener("click", (event) => {
      const button = event.target.closest("[data-expand]");
      if (!button) return;
      const id = button.getAttribute("data-expand");
      if (expanded.has(id)) {
        expanded.delete(id);
      } else {
        expanded.add(id);
      }
      render();
      document.querySelector(`#reg-${CSS.escape(slug(id))}`)?.scrollIntoView({ block: "nearest" });
    });

    loadMore.addEventListener("click", () => {
      visibleLimit += PAGE_SIZE;
      render();
    });

    clearFilters.addEventListener("click", () => {
      searchInput.value = "";
      filtersForm.querySelectorAll("input[type='checkbox']").forEach((input) => {
        input.checked = false;
      });
      visibleLimit = PAGE_SIZE;
      render();
      syncUrl();
      searchInput.focus();
    });

    document.addEventListener("keydown", (event) => {
      const target = event.target;
      const isTyping = target instanceof HTMLInputElement || target instanceof HTMLTextAreaElement || target.isContentEditable;
      if (event.key === "/" && !isTyping) {
        event.preventDefault();
        searchInput.focus();
      }
    });

    buildFilters();
    applyUrlParams();
    render();
  </script>
</body>
</html>
