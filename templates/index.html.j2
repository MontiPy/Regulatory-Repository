<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Regulatory Repository</title>
  <!-- Type is served from system-font stacks (see styles.css :root) so the tool
       loads with no external font CDN — works offline and on internal hosting. -->
  <link rel="stylesheet" href="assets/styles.css">
</head>
<body>

  <header class="site-header">
    <div class="header-inner">
      <div class="header-brand">
        <button type="button" class="header-title" id="home-link">Regulatory Repository</button>
      </div>

      <div class="search-wrap">
        <input id="search" type="search" autocomplete="off" aria-label="Search"
               placeholder="Search title, citation, tags, UN equivalent, or body text…">
      </div>

      <div class="header-actions">
        <button type="button" class="btn-util" id="copy-link">Copy link</button>
        <button type="button" class="btn-util" id="theme-toggle">Dark</button>
      </div>
    </div>

  </header>

  <section id="home" class="home hidden" aria-label="Home">
    <div class="onboard hidden" id="onboard" role="note">
      <span class="onboard-text"><strong>New here?</strong> Start with the system or part you're working on — pick one below or search. Every result links back to its official source.</span>
      <button type="button" class="onboard-dismiss" id="onboard-dismiss" aria-label="Dismiss">×</button>
    </div>

    <div class="home-hero">
      <div class="hero-main">
        <p class="hero-eyebrow">Vehicle regulations · global coverage</p>
        <h1 class="home-title">Find every requirement that governs your part.</h1>
        <p class="coverage-line" id="coverage-line"></p>
        <div class="hero-search">
          <input id="home-search" type="search" autocomplete="off" aria-label="Search regulations"
                 placeholder="Search a part, system, citation, or UN number…">
        </div>
        <div class="hero-chips" id="hero-chips" aria-label="Jump to a system"></div>
        <p class="search-examples" id="search-examples"></p>
      </div>
      <aside class="hero-feature" aria-label="Most-covered systems">
        <div class="feature-head"><span class="feature-label">Most-covered systems</span></div>
        <ol class="feature-list" id="feature-list"></ol>
        <p class="feature-foot" id="feature-foot"></p>
      </aside>
    </div>

    <div class="home-panels">
      <section class="dir-panel" data-panel="systems">
        <div class="dir-head"><span class="dir-label">Browse by System</span><span class="dir-sort" data-sort-for="systems"></span></div>
        <div class="dir-tiles" data-tiles="systems"></div>
        <button type="button" class="dir-more hidden" data-more-for="systems"></button>
      </section>
      <section class="dir-panel" data-panel="commodities">
        <div class="dir-head"><span class="dir-label">Browse by Commodity</span><span class="dir-sort" data-sort-for="commodities"></span></div>
        <div class="dir-tiles" data-tiles="commodities"></div>
        <button type="button" class="dir-more hidden" data-more-for="commodities"></button>
      </section>
    </div>
    <section class="dir-panel dir-panel-market" data-panel="region">
      <div class="dir-head"><span class="dir-label">Browse by Market</span><span class="dir-sort" data-sort-for="region"></span></div>
      <div class="dir-tiles" data-tiles="region"></div>
      <button type="button" class="dir-more hidden" data-more-for="region"></button>
    </section>
  </section>

  <div class="layout">
    <aside class="filters" id="filters-panel" aria-label="Filters">
      <div class="filters-inner">
        <button type="button" class="filters-close" id="filters-close" aria-label="Close filters">×</button>
        <button type="button" class="clear-button hidden" id="clear-filters">Clear all filters</button>
        <details class="avail-section" open>
          <summary>Availability</summary>
          <div class="facet-options" id="avail-options">
            <label class="facet-option"><input type="checkbox" id="avail-full" data-avail="full" checked><span>Full text</span></label>
            <label class="facet-option"><input type="checkbox" id="avail-paywall" data-avail="paywall"><span>Paywall</span></label>
            <label class="facet-option"><input type="checkbox" id="avail-noconn" data-avail="noconn"><span>No live connection</span></label>
          </div>
        </details>
        <form id="filters-form"></form>
      </div>
    </aside>

    <main>
      <button type="button" class="filters-toggle" id="filters-toggle" aria-expanded="false" aria-controls="filters-panel">Filters</button>
      <div class="chip-bar hidden" id="chip-bar" aria-label="Active filters"></div>
      <p id="result-count" aria-live="polite">Showing 0 of 0</p>
      <p id="result-order" class="result-order"></p>
      <section class="cards" id="cards" aria-label="Regulations"></section>
      <button type="button" class="load-more hidden" id="load-more">Load more</button>
    </main>

    <aside class="reader hidden" id="reader" aria-label="Regulation reader">
      <button type="button" class="reader-back" id="reader-back">
        <span class="reader-back-arrow" aria-hidden="true">←</span>
        <span id="reader-back-label">Back to results</span>
      </button>
      <div class="reader-head">
        <div class="reader-title-block">
          <strong class="reader-title" id="reader-title"></strong>
          <div class="reader-trust" id="reader-trust" aria-label="Reader source details"></div>
        </div>
        <button type="button" class="reader-close" id="reader-close" aria-label="Close reader">×</button>
      </div>
      <div class="reader-body" id="reader-body"></div>
    </aside>
  </div>

  <div id="tip" role="tooltip" aria-hidden="true"></div>

  <footer class="site-footer">
    <span>Built {{ build_meta.timestamp }} &nbsp;&bull;&nbsp; {{ build_meta.count }} regulations &nbsp;&bull;&nbsp; {{ build_meta.region_counts|length }} regions</span>
  </footer>
  <script src="assets/vendor/minisearch.min.js"></script>
  <script src="assets/app.js"></script>
</body>
</html>
